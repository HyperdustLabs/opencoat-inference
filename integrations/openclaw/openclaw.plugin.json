{
  "id": "opencoat-inference",
  "name": "OpenCOAT Inference",
  "version": "0.1.0",
  "description": "Routes OpenClaw model traffic through the local OpenCOAT Inference sidecar.",
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:7888/v1"
      },
      "model": {
        "type": "string",
        "default": "opencoat-stub"
      },
      "consumerAgentId": {
        "type": "string",
        "default": "openclaw-local"
      }
    },
    "required": ["baseUrl", "model"]
  }
}
